# ── Anthropic AI ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── SAP Connection ─────────────────────────────────────────────────────────────
# Set SAP_CONNECTOR=mock to use built-in mock data (no real SAP required)
SAP_CONNECTOR=mock

# OData endpoint (when SAP_CONNECTOR=odata)
SAP_ODATA_BASE_URL=https://your-sap-host.company.com
SAP_ODATA_USER=RFC_COPILOT
SAP_ODATA_PASSWORD=secret
SAP_CLIENT=100
SAP_LANGUAGE=FR
SAP_VERSION=auto          # auto | ecc | s4hana
SAP_VERIFY_SSL=true
SAP_TIMEOUT_CONNECT=10.0
SAP_TIMEOUT_READ=30.0
SAP_MAX_RETRIES=3
SAP_RETRY_BACKOFF=1.0

# OAuth2 — S/4HANA Cloud (mutually exclusive with Basic Auth above)
SAP_OAUTH_URL=
SAP_OAUTH_CLIENT_ID=
SAP_OAUTH_CLIENT_SECRET=
SAP_OAUTH_SCOPE=

# Circuit breaker
SAP_CB_FAILURE_THRESHOLD=5
SAP_CB_RECOVERY_TIMEOUT=60

# SAP API Business Hub sandbox (test without a real SAP system)
SAP_SANDBOX=false
SAP_SANDBOX_API_KEY=

# RFC / BAPI endpoint (when SAP_CONNECTOR=rfc — requires pyrfc)
SAP_RFC_HOST=
SAP_RFC_SYSNR=00
SAP_RFC_CLIENT=100
SAP_RFC_USER=
SAP_RFC_PASSWORD=

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
EXECUTION_ENABLED=false
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ── JWT Authentication ─────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-random-32-char-minimum-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── First Admin Seed ───────────────────────────────────────────────────────────
# Created on first startup if no admin exists in the DB
FIRST_ADMIN_EMAIL=admin@sap-copilot.local
FIRST_ADMIN_PASSWORD=changeme

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
# Docker Compose credentials (must match docker-compose.yml)
POSTGRES_DB=sap_copilot
POSTGRES_USER=sap_user
POSTGRES_PASSWORD=sap_pass

# Application connection string
# Docker:     use the service name "db" as the host
# Local dev:  use "localhost" (DATABASE_URL_LOCAL below)
DATABASE_URL=postgresql+asyncpg://sap_user:sap_pass@db:5432/sap_copilot
DATABASE_URL_LOCAL=postgresql+asyncpg://sap_user:sap_pass@localhost:5432/sap_copilot
TEST_DATABASE_URL=postgresql+asyncpg://sap_user:sap_pass@localhost:5432/sap_copilot_test
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
