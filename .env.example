# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── SAP Connection ─────────────────────────────────────────────────────────────
# Set SAP_CONNECTOR=mock to use built-in mock data (no real SAP required)
SAP_CONNECTOR=mock

# OData endpoint (when SAP_CONNECTOR=odata)
SAP_ODATA_BASE_URL=https://your-sap-host/sap/opu/odata/sap
SAP_ODATA_USER=SAP_USER
SAP_ODATA_PASSWORD=SAP_PASS

# RFC / BAPI endpoint (when SAP_CONNECTOR=rfc — requires pyrfc)
SAP_RFC_HOST=
SAP_RFC_SYSNR=00
SAP_RFC_CLIENT=100
SAP_RFC_USER=
SAP_RFC_PASSWORD=

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production
EXECUTION_ENABLED=false

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
